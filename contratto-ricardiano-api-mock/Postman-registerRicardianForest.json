          "path": ["api", "ricardian", "pdf", "{{forestUnitId}}", "download"]
        }
      }
    },
    {
      "name": "4) Upload CAdES .p7m -> sets {{pdfHash}} {{cadesHash}} {{cadesUri}} {{signerCommonName}} {{signerSerialNumber}} {{validOffchain}}",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{API_URL}}/api/ricardian/cades/upload",
          "host": ["{{API_URL}}"],
          "path": ["api", "ricardian", "cades", "upload"]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "forestUnitId",
              "value": "{{forestUnitId}}",
              "type": "text"
            },
            {
              "key": "useIPFS",
              "value": "false",
              "type": "text"
            },
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "console.log('UPLOAD CADES response:', j);",
              "if (j && j.forestUnitId) pm.collectionVariables.set('forestUnitId', j.forestUnitId);",
              "if (j && j.hashes && j.hashes.pdfHash) pm.collectionVariables.set('pdfHash', j.hashes.pdfHash);",
              "if (j && j.hashes && j.hashes.cadesHash) pm.collectionVariables.set('cadesHash', j.hashes.cadesHash);",
              "if (j && j.storage && j.storage.cadesUri) pm.collectionVariables.set('cadesUri', j.storage.cadesUri);",
              "if (j && j.signer) {",
              "  if (j.signer.commonName !== undefined) pm.collectionVariables.set('signerCommonName', j.signer.commonName);",
              "  if (j.signer.serialNumber !== undefined) pm.collectionVariables.set('signerSerialNumber', j.signer.serialNumber);",
              "  if (j.signer.organization !== undefined) pm.collectionVariables.set('signerOrganization', j.signer.organization);",
              "  if (j.signer.country !== undefined) pm.collectionVariables.set('signerCountry', j.signer.country);",
              "  if (j.signer.policy !== undefined) pm.collectionVariables.set('signerPolicy', j.signer.policy);",
              "  if (j.signer.keyUsage !== undefined) pm.collectionVariables.set('signerKeyUsage', j.signer.keyUsage);",
              "  if (j.signer.extendedKeyUsage !== undefined) pm.collectionVariables.set('signerExtendedKeyUsage', j.signer.extendedKeyUsage);",
              "  if (j.signer.issuer !== undefined) pm.collectionVariables.set('signerIssuer', j.signer.issuer);",
              "  if (j.signer.validFrom !== undefined) pm.collectionVariables.set('signerValidFrom', j.signer.validFrom);",
              "  if (j.signer.validTo !== undefined) pm.collectionVariables.set('signerValidTo', j.signer.validTo);",
              "}",
              "if (j && j.validOffchain !== undefined) pm.collectionVariables.set('validOffchain', String(j.validOffchain));"
            ]
          }
        }
      ]
    },
    {
      "name": "5) WRITE 2 CADES -> sets {{cadesTxHash}} {{cadesBlockNumber}}",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{API_URL}}/api/contract/write-2-cades",
          "host": ["{{API_URL}}"],
          "path": ["api", "contract", "write-2-cades"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"forestUnitId\": \"{{forestUnitId}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "console.log('WRITE 2 CADES response:', j);",
              "if (j && j.ok !== true) {",
              "  console.log('WRITE 2 CADES failed response:', j);",
              "}",
              "if (j && j.onchain && j.onchain.txHash) pm.collectionVariables.set('cadesTxHash', j.onchain.txHash);",
              "if (j && j.onchain && j.onchain.blockNumber !== undefined) pm.collectionVariables.set('cadesBlockNumber', String(j.onchain.blockNumber));",
              "if (j && j.countersignature && j.countersignature.pdfHash) pm.collectionVariables.set('pdfHash', j.countersignature.pdfHash);",
              "if (j && j.countersignature && j.countersignature.cadesHash) pm.collectionVariables.set('cadesHash', j.countersignature.cadesHash);",
              "if (j && j.countersignature && j.countersignature.cadesUri) pm.collectionVariables.set('cadesUri', j.countersignature.cadesUri);",
              "if (j && j.countersignature && j.countersignature.signerCommonName !== undefined) pm.collectionVariables.set('signerCommonName', j.countersignature.signerCommonName);",
              "if (j && j.countersignature && j.countersignature.signerSerialNumber !== undefined) pm.collectionVariables.set('signerSerialNumber', j.countersignature.signerSerialNumber);",
              "if (j && j.countersignature && j.countersignature.validOffchain !== undefined) pm.collectionVariables.set('validOffchain', String(j.countersignature.validOffchain));"
            ]
          }
        }
      ]
    },
    {
      "name": "5b) Upload CAdES CLIENT .p7m.p7m -> sets {{innerCadesHash}} {{clientCadesHash}} {{clientCadesUri}} {{clientSignerCommonName}} {{clientSignerSerialNumber}} {{clientValidOffchain}}",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{API_URL}}/api/ricardian/cades/client-upload",
          "host": ["{{API_URL}}"],
          "path": ["api", "ricardian", "cades", "client-upload"]
        },
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "forestUnitId",
              "value": "{{forestUnitId}}",
              "type": "text"
            },
            {
              "key": "useIPFS",
              "value": "false",
              "type": "text"
            },
            {
              "key": "file",
              "type": "file",
              "src": "",
              "description": "Il .p7m.p7m: la firma del CLIENTE annidata sopra il .p7m del firmatario (call 4)."
            }
          ]
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Prerequisito: la firma del firmatario deve essere stata caricata (call 4) e registrata (call 5).",
              "const cadesHash = pm.collectionVariables.get('cadesHash');",
              "if (!cadesHash) {",
              "  console.warn('[!] cadesHash non impostato. Esegui prima la call 4 (Upload CAdES) e la call 5 (WRITE 2 CADES).');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "console.log('UPLOAD CADES CLIENT response:', j);",
              "if (j && j.ok !== true) {",
              "  console.log('UPLOAD CADES CLIENT failed response:', j);",
              "}",
              "if (j && j.forestUnitId) pm.collectionVariables.set('forestUnitId', j.forestUnitId);",
              "if (j && j.hashes && j.hashes.innerCadesHash) pm.collectionVariables.set('innerCadesHash', j.hashes.innerCadesHash);",
              "if (j && j.hashes && j.hashes.clientCadesHash) pm.collectionVariables.set('clientCadesHash', j.hashes.clientCadesHash);",
              "if (j && j.storage && j.storage.clientCadesUri) pm.collectionVariables.set('clientCadesUri', j.storage.clientCadesUri);",
              "if (j && j.signer) {",
              "  if (j.signer.commonName !== undefined) pm.collectionVariables.set('clientSignerCommonName', j.signer.commonName);",
              "  if (j.signer.serialNumber !== undefined) pm.collectionVariables.set('clientSignerSerialNumber', j.signer.serialNumber);",
              "  if (j.signer.organization !== undefined) pm.collectionVariables.set('clientSignerOrganization', j.signer.organization);",
              "  if (j.signer.country !== undefined) pm.collectionVariables.set('clientSignerCountry', j.signer.country);",
              "  if (j.signer.issuer !== undefined) pm.collectionVariables.set('clientSignerIssuer', j.signer.issuer);",
              "  if (j.signer.validFrom !== undefined) pm.collectionVariables.set('clientSignerValidFrom', j.signer.validFrom);",
              "  if (j.signer.validTo !== undefined) pm.collectionVariables.set('clientSignerValidTo', j.signer.validTo);",
              "}",
              "if (j && j.validOffchain !== undefined) pm.collectionVariables.set('clientValidOffchain', String(j.validOffchain));"
            ]
          }
        }
      ]
    },
    {
      "name": "5c) WRITE 3 CLIENT COUNTERSIGN -> sets {{clientCadesTxHash}} {{clientCadesBlockNumber}}",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{API_URL}}/api/contract/write-3-client-countersign",
          "host": ["{{API_URL}}"],
          "path": ["api", "contract", "write-3-client-countersign"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"forestUnitId\": \"{{forestUnitId}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Prerequisito on-chain: la firma del firmatario deve essere stata registrata (call 5 -> cadesTxHash).",
              "const cadesTxHash = pm.collectionVariables.get('cadesTxHash');",
              "if (!cadesTxHash) {",
              "  console.warn('[!] cadesTxHash non impostato. Esegui prima la call 5 (WRITE 2 CADES) prima di registrare la controfirma cliente.');",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "console.log('WRITE 3 CLIENT COUNTERSIGN response:', j);",
              "if (j && j.ok !== true) {",
              "  console.log('WRITE 3 CLIENT COUNTERSIGN failed response:', j);",
              "}",
              "if (j && j.onchain && j.onchain.txHash) pm.collectionVariables.set('clientCadesTxHash', j.onchain.txHash);",
              "if (j && j.onchain && j.onchain.blockNumber !== undefined) pm.collectionVariables.set('clientCadesBlockNumber', String(j.onchain.blockNumber));",
              "if (j && j.clientCountersignature) {",
              "  if (j.clientCountersignature.innerCadesHash) pm.collectionVariables.set('innerCadesHash', j.clientCountersignature.innerCadesHash);",
              "  if (j.clientCountersignature.clientCadesHash) pm.collectionVariables.set('clientCadesHash', j.clientCountersignature.clientCadesHash);",
              "  if (j.clientCountersignature.clientCadesUri) pm.collectionVariables.set('clientCadesUri', j.clientCountersignature.clientCadesUri);",
              "  if (j.clientCountersignature.signerCommonName !== undefined) pm.collectionVariables.set('clientSignerCommonName', j.clientCountersignature.signerCommonName);",
              "  if (j.clientCountersignature.signerSerialNumber !== undefined) pm.collectionVariables.set('clientSignerSerialNumber', j.clientCountersignature.signerSerialNumber);",
              "  if (j.clientCountersignature.validOffchain !== undefined) pm.collectionVariables.set('clientValidOffchain', String(j.clientCountersignature.validOffchain));",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "6) VERIFY (On-chain + proofs + optional IPFS hash + countersignature + clientCountersignature) -> uses {{forestUnitId}}",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "{{API_URL}}/api/contract/verify",
          "host": ["{{API_URL}}"],
          "path": ["api", "contract", "verify"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"forestUnitId\": \"{{forestUnitId}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "console.log('VERIFY response:', j);",
              "",
              "// --- Firma del firmatario (countersignature) ---",
              "const cs = j && j.countersignature;",
              "if (cs && cs.existsOnChain && cs.matches) {",
              "  console.log('[firmatario] pdfHashMatches =', cs.matches.pdfHashMatches, '| cadesHashMatches =', cs.matches.cadesHashMatches, '| cadesUriMatches =', cs.matches.cadesUriMatches);",
              "} else if (cs && cs.existsOnChain === false) {",
              "  console.warn('[firmatario] controfirma NON presente on-chain.');",
              "}",
              "",
              "// --- Controfirma del cliente (clientCountersignature) ---",
              "const cc = j && j.clientCountersignature;",
              "if (cc && cc.existsOnChain && cc.matches) {",
              "  console.log('[cliente] innerCadesHashMatches =', cc.matches.innerCadesHashMatches, '| clientCadesHashMatches =', cc.matches.clientCadesHashMatches, '| clientCadesUriMatches =', cc.matches.clientCadesUriMatches, '| nestingMatchesUserSignature =', cc.matches.nestingMatchesUserSignature);",
              "} else if (cc && cc.existsOnChain === false) {",
              "  console.warn('[cliente] controfirma NON presente on-chain (esegui 5b e 5c).');",
              "} else if (cc && cc.skipped) {",
              "  console.warn('[cliente] verifica saltata:', cc.reason);",
              "}"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
