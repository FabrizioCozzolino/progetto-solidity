{
  "info": {
    "name": "Register Ricardian Forest - 3 CALLS (WRITE + PDF + VERIFY)",
    "_postman_id": "bbbbbbbb-1111-2222-3333-cccccccccccc",
    "description": "Only 3 calls: 1) /api/contract/write (does all steps internally) 2) view PDF (kept as 4.5) 3) /api/contract/verify (on-chain + proofs + optional IPFS hash). Auto-populates collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) WRITE (All-in-one) -> sets {{forestUnitId}} {{merkleRoot}} {{ricardianHash}} {{storageUri}} {{txHash}}",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{API_URL}}/api/contract/write",
          "host": ["{{API_URL}}"],
          "path": ["api", "contract", "write"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"operator\",\n  \"password\": \"1234567!\",\n  \"useIPFS\": false\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const j = pm.response.json();",
              "if (!j || j.ok !== true) {",
              "  console.log('WRITE failed response:', j);",
              "}",
              "if (j && j.forestUnitId) pm.collectionVariables.set('forestUnitId', j.forestUnitId);",
              "if (j && j.merkleRoot) pm.collectionVariables.set('merkleRoot', j.merkleRoot);",
              "if (j && j.ricardianHash) pm.collectionVariables.set('ricardianHash', j.ricardianHash);",
              "if (j && j.storageUri) pm.collectionVariables.set('storageUri', j.storageUri);",
              "if (j && j.onchain && j.onchain.txHash) pm.collectionVariables.set('txHash', j.onchain.txHash);",
              "if (j && j.onchain && j.onchain.blockNumber !== undefined) pm.collectionVariables.set('blockNumber', String(j.onchain.blockNumber));",
              "if (j && j.pdfEndpoint) pm.collectionVariables.set('pdfEndpoint', j.pdfEndpoint);"
            ]
          }
        }
      ]
    },
    {
      "name": "4.5) View Ricardian PDF (kept) -> uses {{forestUnitId}}",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{API_URL}}/api/ricardian/pdf/{{forestUnitId}}",
          "host": ["{{API_URL}}"],
          "path": ["api", "ricardian", "pdf", "{{forestUnitId}}"]
        }
      }
    },
    {
      "name": "3) VERIFY (On-chain + proofs + optional IPFS hash) -> uses {{forestUnitId}}",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{API_URL}}/api/contract/verify",
          "host": ["{{API_URL}}"],
          "path": ["api", "contract", "verify"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"forestUnitId\": \"{{forestUnitId}}\"\n}"
        }
      }
    }
  ],
  "variable": [
    { "key": "API_URL", "value": "http://localhost:3000" },
    { "key": "forestUnitId", "value": "" },
    { "key": "merkleRoot", "value": "" },
    { "key": "ricardianHash", "value": "" },
    { "key": "storageUri", "value": "" },
    { "key": "txHash", "value": "" },
    { "key": "blockNumber", "value": "" },
    { "key": "pdfEndpoint", "value": "" }
  ]
}